{
  "manifest_version": 3,
  "name": "YouTube 2x Speed",
  "version": "1.0",
  "description": "Автоматически устанавливает скорость 2x для видео на YouTube.",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube2x@roman.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
